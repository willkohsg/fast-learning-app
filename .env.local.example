# Copy to .env.local and fill in values
# .env.local is gitignored — never commit real keys

# Convex — written by `npx convex dev --once --configure=new`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Resend (get at https://resend.com/api-keys)
RESEND_API_KEY=

# Public app URL (set on Vercel; used for absolute links in email)
NEXT_PUBLIC_APP_URL=http://localhost:3000
